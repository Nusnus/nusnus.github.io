---
import ActivityGraph from '@components/widgets/ActivityGraph';
import ContributionLineChart from '@components/widgets/ContributionLineChart';
import SectionHeader from '@components/ui/SectionHeader.astro';
import { loadContributionGraph } from '@lib/data/loader';

const graph = await loadContributionGraph();
const weeks = graph?.weeks ?? [];
---

{
  weeks.length > 0 && (
    <section id="activity-graph" class="animate-section" aria-label="Activity graphs">
      <SectionHeader title="Activity Graph" subtitle="Contribution trends and breakdown" />

      <div class="flex flex-col gap-5">
        <div class="bg-bg-surface/50 ring-border/50 overflow-x-auto rounded-xl p-4 shadow-[var(--shadow-soft)] ring-1">
          <p class="text-text-muted mb-3 text-xs font-medium tracking-wider uppercase">
            Daily contributions (last 35 days)
          </p>
          <ContributionLineChart client:visible weeks={weeks} />
        </div>

        <div class="bg-bg-surface/50 ring-border/50 overflow-x-auto rounded-xl p-4 shadow-[var(--shadow-soft)] ring-1">
          <p class="text-text-muted mb-3 text-xs font-medium tracking-wider uppercase">
            Monthly breakdown
          </p>
          <ActivityGraph client:visible weeks={weeks} />
        </div>
      </div>
    </section>
  )
}
