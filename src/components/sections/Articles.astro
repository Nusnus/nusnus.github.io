---
import Card from '@components/ui/Card.astro';
import Badge from '@components/ui/Badge.astro';
import { LINKEDIN_ARTICLES } from '@config';
import { formatDate } from '@lib/utils/date';
---

<section id="writing" aria-label="Writing">
  <div class="mb-6 flex items-center gap-3">
    <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Writing</h2>
    <Badge variant="accent" size="sm">Soon</Badge>
  </div>
  <p class="text-text-secondary mb-6">
    Thoughts on distributed systems, open source leadership, and software engineering philosophy
  </p>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    {
      LINKEDIN_ARTICLES.map((article) => {
        const hasNativePage = !!article.slug;

        return hasNativePage ? (
          <Card class="relative">
            <a
              href={`/articles/${article.slug}`}
              class="absolute inset-0 z-0"
              aria-label={`Read ${article.title}`}
            />
            <Badge variant="ghost" size="sm" class="mb-3">
              Published on LinkedIn
            </Badge>
            <h3 class="text-text-primary mb-2 text-base font-semibold">{article.title}</h3>
            <p class="text-text-secondary mb-3 text-sm">{article.excerpt}</p>
            <div class="text-text-muted flex items-center justify-between text-xs">
              <time datetime={article.publishedAt}>{formatDate(article.publishedAt)}</time>
              <a
                href={article.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent relative z-10 inline-flex items-center gap-1 hover:underline"
              >
                Read on LinkedIn
                <svg
                  class="h-3 w-3"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </a>
            </div>
          </Card>
        ) : (
          <Card href={article.url}>
            <Badge variant="ghost" size="sm" class="mb-3">
              Published on LinkedIn
            </Badge>
            <h3 class="text-text-primary mb-2 text-base font-semibold">{article.title}</h3>
            <p class="text-text-secondary mb-3 text-sm">{article.excerpt}</p>
            <div class="text-text-muted flex items-center justify-between text-xs">
              <time datetime={article.publishedAt}>{formatDate(article.publishedAt)}</time>
              <span class="text-accent inline-flex items-center gap-1">
                Read on LinkedIn
                <svg
                  class="h-3 w-3"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </span>
            </div>
          </Card>
        );
      })
    }
  </div>

  <p class="text-text-muted mt-6 text-sm">
    More writing coming soon. Follow on
    <a
      href="https://www.linkedin.com/in/tomer-nosrati"
      target="_blank"
      rel="noopener noreferrer"
      class="text-accent hover:underline"
    >
      LinkedIn
    </a>
    for updates.
  </p>
</section>
