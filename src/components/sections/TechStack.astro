---
const categories = [
  {
    name: 'Backend',
    items: ['Python', 'Django', 'Flask'],
  },
  {
    name: 'Infrastructure',
    items: ['Docker', 'Redis', 'RabbitMQ', 'PostgreSQL', 'AWS', 'Nginx'],
  },
  {
    name: 'Tooling',
    items: ['Git', 'GitHub Actions', 'Jenkins', 'Bash'],
  },
  {
    name: 'Editors',
    items: ['PyCharm', 'VSCode', 'Vim', 'Obsidian'],
  },
];
---

<section id="stack" aria-label="Tech stack">
  <h2 class="mb-2 text-3xl font-bold tracking-tight">Stack</h2>
  <p class="text-text-secondary mb-6">Technologies and tools I work with daily</p>

  <div class="space-y-6">
    {
      categories.map((category) => (
        <div>
          <h3 class="text-text-muted mb-3 text-sm font-semibold tracking-wider uppercase">
            {category.name}
          </h3>
          <div class="flex flex-wrap gap-2">
            {category.items.map((item) => (
              <span class="border-border bg-bg-surface text-text-secondary hover:border-accent/40 hover:text-text-primary rounded-lg border px-3 py-1.5 text-sm transition-colors duration-100">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
