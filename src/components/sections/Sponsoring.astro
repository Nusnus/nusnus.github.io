---
import Button from '@components/ui/Button.astro';
import { OPEN_COLLECTIVE_URL } from '@config';
---

<section id="sponsoring" aria-label="Sponsor Celery">
  <div
    class="border-accent/20 bg-accent-muted relative overflow-hidden rounded-xl border p-6 md:p-8"
  >
    <!-- Decorative gradient orb -->
    <div
      class="pointer-events-none absolute -top-20 -right-20 h-64 w-64 rounded-full opacity-30 blur-3xl"
      style="background: radial-gradient(circle, var(--color-accent-glow) 0%, transparent 70%)"
      aria-hidden="true"
    >
    </div>

    <div class="relative flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div class="max-w-xl">
        <!-- Celery leaf icon -->
        <div class="mb-3 flex items-center gap-2">
          <svg
            class="text-accent h-6 w-6"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75C7 8 17 8 17 8z"
            ></path>
          </svg>
          <h2 class="text-text-primary text-2xl font-bold">Support Celery's Development</h2>
        </div>

        <p class="text-text-secondary mb-4 text-sm leading-relaxed">
          Celery powers distributed task queues for thousands of companies worldwide. Your
          sponsorship directly funds ongoing maintenance, CI/CD infrastructure, and the development
          of new features for the entire ecosystem.
        </p>

        <Button href={OPEN_COLLECTIVE_URL} variant="primary" size="md">
          Become a Sponsor
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </Button>
      </div>
    </div>
  </div>
</section>
