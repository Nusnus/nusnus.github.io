---
import Card from '@components/ui/Card.astro';
import Badge from '@components/ui/Badge.astro';
import { loadRepos } from '@lib/data/loader';
import { formatCompactNumber, relativeTime } from '@lib/utils/date';

const repos = (await loadRepos()) ?? [];

const roleBadgeVariant = {
  owner: 'accent' as const,
  creator: 'accent' as const,
  lead: 'filled' as const,
  contributor: 'ghost' as const,
};

const roleLabel = {
  owner: 'Owner',
  creator: 'Creator',
  lead: 'Lead',
  contributor: 'Contributor',
};
---

<section id="projects" aria-label="Active projects">
  <h2 class="mb-2 text-3xl font-bold tracking-tight">Active Projects</h2>
  <p class="text-text-secondary mb-6">Open source projects I maintain and contribute to</p>

  <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
    {
      repos.map((repo) => (
        <Card href={repo.htmlUrl}>
          <div class="mb-3 flex items-start justify-between">
            <h3 class="text-text-primary font-mono text-base font-semibold">{repo.fullName}</h3>
            <Badge variant={roleBadgeVariant[repo.role]} size="sm">
              {roleLabel[repo.role]}
            </Badge>
          </div>

          <p class="text-text-secondary mb-4 line-clamp-2 text-sm">{repo.description}</p>

          <div class="text-text-muted flex flex-wrap items-center gap-3 text-xs">
            <span class="flex items-center gap-1">
              <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z" />
              </svg>
              <span data-live-repo={repo.fullName} data-live-field="stars">
                {formatCompactNumber(repo.stars)}
              </span>
            </span>
            <span class="flex items-center gap-1">
              <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75v-.878a2.25 2.25 0 111.5 0v.878a2.25 2.25 0 01-2.25 2.25h-1.5v2.128a2.251 2.251 0 11-1.5 0V8.5h-1.5A2.25 2.25 0 013.5 6.25v-.878a2.25 2.25 0 111.5 0z" />
              </svg>
              <span data-live-repo={repo.fullName} data-live-field="forks">
                {formatCompactNumber(repo.forks)}
              </span>
            </span>
            {repo.language && (
              <span class="flex items-center gap-1">
                <span class="bg-accent h-2.5 w-2.5 rounded-full" aria-hidden="true" />
                {repo.language}
              </span>
            )}
            <span class="ml-auto">
              Updated{' '}
              <span data-live-repo={repo.fullName} data-live-field="lastPush">
                {relativeTime(repo.lastPush)}
              </span>
            </span>
          </div>

          {repo.contributorRank && (
            <p class="text-accent mt-2 font-mono text-xs">
              <span data-live-repo={repo.fullName} data-live-field="contributorRank">
                #{repo.contributorRank}
              </span>{' '}
              contributor
            </p>
          )}
        </Card>
      ))
    }
  </div>
</section>
