---
import RepoCard from '@components/ui/RepoCard.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import { loadCeleryOrgRepos } from '@lib/data/loader';

const repos = (await loadCeleryOrgRepos()) ?? [];
---

<section id="celery-organization" class="animate-section" aria-label="Celery Organization">
  <SectionHeader title="Celery Organization">
    <Fragment slot="default">
      <!-- Empty: subtitle handled below for link support -->
    </Fragment>
  </SectionHeader>
  <p class="text-text-secondary -mt-4 mb-6 pl-4 text-sm">
    Additional repositories I contribute to across the
    <a
      href="https://github.com/celery"
      target="_blank"
      rel="noopener noreferrer"
      class="text-accent hover:underline"
    >
      Celery organization
    </a>
  </p>

  <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
    {repos.map((repo) => <RepoCard repo={repo} />)}
  </div>
</section>
