---
import ContributionGraph from '@components/widgets/ContributionGraph';
import { loadContributionGraph } from '@lib/data/loader';
import { formatCompactNumber, calculateStreak } from '@lib/utils/date';

const graph = loadContributionGraph();
const totalContributions = graph?.totalContributions ?? 0;
const weeks = graph?.weeks ?? [];

const allDays = weeks.flatMap((w) => w.contributionDays);
const streak = calculateStreak(allDays);
---

<section id="activity" class="relative" aria-label="Activity overview">
  <!-- Living Canvas: heatmap as subtle background texture -->
  <div
    class="pointer-events-none absolute inset-0 overflow-hidden opacity-[0.06]"
    aria-hidden="true"
  >
    {
      weeks.length > 0 && (
        <ContributionGraph client:visible weeks={weeks} totalContributions={totalContributions} />
      )
    }
  </div>

  <!-- Foreground content -->
  <div class="relative z-10">
    <h2 class="mb-1 text-3xl font-bold tracking-tight">Contributions</h2>
    <p class="text-text-secondary mb-5 text-sm">Contribution heatmap for the last year</p>

    <!-- Contribution heatmap -->
    {
      weeks.length > 0 && (
        <div class="bg-bg-surface/50 ring-border/50 mb-6 overflow-x-auto rounded-xl p-4 ring-1">
          <ContributionGraph client:visible weeks={weeks} totalContributions={totalContributions} />
        </div>
      )
    }

    <!-- Summary stats -->
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
      <div class="bg-bg-surface/50 ring-border/40 rounded-lg p-3 ring-1">
        <p class="text-accent font-mono text-xl font-bold" data-live="totalContributions">
          {formatCompactNumber(totalContributions)}
        </p>
        <p class="text-text-muted text-xs">contributions</p>
      </div>
      <div class="bg-bg-surface/50 ring-border/40 rounded-lg p-3 ring-1">
        <p class="text-accent font-mono text-xl font-bold">
          🔥 <span data-live="streak">{streak}</span>
        </p>
        <p class="text-text-muted text-xs">day streak</p>
      </div>
      {
        graph && (
          <div class="bg-bg-surface/50 ring-border/40 rounded-lg p-3 ring-1">
            <p class="text-accent font-mono text-xl font-bold" data-live="totalCommits">
              {formatCompactNumber(graph.totalCommits)}
            </p>
            <p class="text-text-muted text-xs">commits</p>
          </div>
        )
      }
      {
        graph && (
          <div class="bg-bg-surface/50 ring-border/40 rounded-lg p-3 ring-1">
            <p class="text-accent font-mono text-xl font-bold" data-live="totalPRs">
              {formatCompactNumber(graph.totalPRs)}
            </p>
            <p class="text-text-muted text-xs">pull requests</p>
          </div>
        )
      }
    </div>
  </div>
</section>
