---
import ContributionGraph from '@components/widgets/ContributionGraph';
import SectionHeader from '@components/ui/SectionHeader.astro';
import {
  loadContributionGraph,
  loadRepos,
  loadCeleryOrgRepos,
  loadProfile,
} from '@lib/data/loader';
import { formatCompactNumber, calculateStreak } from '@lib/utils/date';
import { GITHUB_USERNAME } from '@config';

const graph = await loadContributionGraph();
const totalContributions = graph?.totalContributions ?? 0;
const weeks = graph?.weeks ?? [];

const allDays = weeks.flatMap((w) => w.contributionDays);
const streak = calculateStreak(allDays);

// ── Trophy data ──
const repos = (await loadRepos()) ?? [];
const orgRepos = (await loadCeleryOrgRepos()) ?? [];
const profile = await loadProfile();

const allRepos = [...repos, ...orgRepos];
const totalStars = allRepos.reduce((sum, r) => sum + r.stars, 0);
const topRepo = repos.find((r) => r.fullName === 'celery/celery');
const createdRepo = repos.find((r) => r.role === 'creator');

interface Trophy {
  icon: string;
  value: string;
  label: string;
  detail: string;
  link?: string;
}

const commitsUrl = (fullName: string) =>
  `https://github.com/${fullName}/commits?author=${GITHUB_USERNAME}`;

const trophies: Trophy[] = [
  {
    icon: '⭐',
    value: formatCompactNumber(totalStars),
    label: 'Total Stars',
    detail: 'across maintained repos',
  },
  ...(topRepo?.contributorRank
    ? [
        {
          icon: '🏆',
          value: `#${topRepo.contributorRank}`,
          label: 'Contributor',
          detail: topRepo.fullName,
          link: commitsUrl(topRepo.fullName),
        },
      ]
    : []),
  ...(createdRepo
    ? [
        {
          icon: '🏗️',
          value: 'Creator',
          label: createdRepo.name,
          detail: 'original author',
          link: commitsUrl(createdRepo.fullName),
        },
      ]
    : []),
  ...(graph
    ? [
        {
          icon: '👀',
          value: formatCompactNumber(graph.totalReviews),
          label: 'Code Reviews',
          detail: 'this year',
        },
      ]
    : []),
  ...(profile
    ? [
        {
          icon: '👥',
          value: String(profile.followers),
          label: 'Followers',
          detail: 'on GitHub',
        },
      ]
    : []),
];
---

<section id="activity" class="animate-section relative" aria-label="Activity overview">
  <!-- Living Canvas: heatmap as subtle background texture -->
  <div
    class="pointer-events-none absolute inset-0 overflow-hidden opacity-[0.06]"
    aria-hidden="true"
  >
    {
      weeks.length > 0 && (
        <ContributionGraph client:visible weeks={weeks} totalContributions={totalContributions} />
      )
    }
  </div>

  <!-- Foreground content -->
  <div class="relative z-10">
    <SectionHeader title="Contributions" subtitle="Contribution heatmap for the last year" />

    <!-- Contribution heatmap -->
    {
      weeks.length > 0 && (
        <div class="bg-bg-surface/50 ring-border/50 mb-6 overflow-x-auto rounded-xl p-4 shadow-[var(--shadow-soft)] ring-1">
          <ContributionGraph client:visible weeks={weeks} totalContributions={totalContributions} />
        </div>
      )
    }

    <!-- Summary stats -->
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
      <div
        class="bg-bg-surface/60 ring-border/40 group hover:ring-accent/30 rounded-xl p-4 ring-1 backdrop-blur-sm transition-all duration-200 hover:shadow-[var(--shadow-glow)]"
      >
        <p
          class="text-accent font-mono text-xl font-bold transition-transform duration-200 group-hover:scale-105"
          data-live="totalContributions"
        >
          {formatCompactNumber(totalContributions)}
        </p>
        <p class="text-text-muted mt-0.5 text-xs">contributions</p>
      </div>
      <div
        class="bg-bg-surface/60 ring-border/40 group hover:ring-accent/30 rounded-xl p-4 ring-1 backdrop-blur-sm transition-all duration-200 hover:shadow-[var(--shadow-glow)]"
      >
        <p
          class="text-accent font-mono text-xl font-bold transition-transform duration-200 group-hover:scale-105"
        >
          <span data-live="streak">{streak}</span>
        </p>
        <p class="text-text-muted mt-0.5 text-xs">day streak</p>
      </div>
      {
        graph && (
          <div class="bg-bg-surface/60 ring-border/40 group hover:ring-accent/30 rounded-xl p-4 ring-1 backdrop-blur-sm transition-all duration-200 hover:shadow-[var(--shadow-glow)]">
            <p
              class="text-accent font-mono text-xl font-bold transition-transform duration-200 group-hover:scale-105"
              data-live="totalCommits"
            >
              {formatCompactNumber(graph.totalCommits)}
            </p>
            <p class="text-text-muted mt-0.5 text-xs">commits</p>
          </div>
        )
      }
      {
        graph && (
          <div class="bg-bg-surface/60 ring-border/40 group hover:ring-accent/30 rounded-xl p-4 ring-1 backdrop-blur-sm transition-all duration-200 hover:shadow-[var(--shadow-glow)]">
            <p
              class="text-accent font-mono text-xl font-bold transition-transform duration-200 group-hover:scale-105"
              data-live="totalPRs"
            >
              {formatCompactNumber(graph.totalPRs)}
            </p>
            <p class="text-text-muted mt-0.5 text-xs">pull requests</p>
          </div>
        )
      }
    </div>

    <!-- Trophies -->
    {
      trophies.length > 0 && (
        <div class="mt-8">
          <p class="text-text-muted mb-3 text-xs font-medium tracking-wider uppercase">
            Achievements
          </p>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
            {trophies.map((trophy) => {
              const Tag = trophy.link ? 'a' : 'div';
              return (
                <Tag
                  class:list={[
                    'bg-bg-surface/60 ring-border/40 group flex flex-col items-center rounded-xl p-4 text-center ring-1 backdrop-blur-sm transition-all duration-200',
                    trophy.link &&
                      'hover:ring-accent/40 cursor-pointer hover:-translate-y-0.5 hover:shadow-[var(--shadow-glow)]',
                  ]}
                  href={trophy.link}
                  target={trophy.link ? '_blank' : undefined}
                  rel={trophy.link ? 'noopener noreferrer' : undefined}
                >
                  <span
                    class="mb-1.5 text-2xl transition-transform duration-200 group-hover:scale-110"
                    aria-hidden="true"
                  >
                    {trophy.icon}
                  </span>
                  <p class="text-accent font-mono text-lg leading-tight font-bold">
                    {trophy.value}
                  </p>
                  <p class="text-text-primary mt-0.5 text-xs font-medium">{trophy.label}</p>
                  <p class="text-text-muted text-[10px]">{trophy.detail}</p>
                </Tag>
              );
            })}
          </div>
        </div>
      )
    }
  </div>
</section>
