---
import { loadProfile } from '@lib/data/loader';
import ThemeToggle from '@components/widgets/ThemeToggle';

const profile = await loadProfile();
---

<!-- Mobile Header — visible only below md breakpoint -->
<header
  class="border-accent/30 bg-bg-base/95 fixed top-0 right-0 left-0 z-40 flex items-center justify-between border-b px-4 py-2.5 backdrop-blur-sm md:hidden"
>
  <div class="flex items-center gap-3">
    <img
      src={profile?.avatarUrl ?? 'https://avatars.githubusercontent.com/u/4662342?v=4'}
      alt="Tomer Nosrati"
      width="32"
      height="32"
      class="rounded-full"
      loading="eager"
    />
    <div>
      <p class="text-sm leading-tight font-semibold">Tomer Nosrati</p>
      <p class="text-accent font-mono text-xs">@Nusnus</p>
    </div>
  </div>

  <div class="flex items-center gap-1">
    <ThemeToggle client:load />
    <button
      id="mobile-menu-toggle"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
      class="text-text-muted hover:bg-bg-surface hover:text-text-primary flex h-9 w-9 items-center justify-center rounded-lg transition-colors"
    >
      <!-- Hamburger icon -->
      <svg
        class="hamburger-icon h-5 w-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
      <!-- Close icon (hidden by default) -->
      <svg
        class="close-icon hidden h-5 w-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile Drawer Overlay -->
<div
  id="mobile-drawer-backdrop"
  class="fixed inset-0 z-40 hidden bg-black/50 backdrop-blur-sm md:hidden"
  aria-hidden="true"
>
</div>

<!-- Mobile Drawer -->
<nav
  id="mobile-drawer"
  class="bg-bg-base fixed top-0 right-0 bottom-0 z-50 w-72 translate-x-full overflow-y-auto shadow-xl transition-transform duration-300 ease-in-out md:hidden"
  aria-label="Mobile navigation"
>
  <div class="flex items-center justify-end px-4 py-3">
    <button
      id="mobile-drawer-close"
      aria-label="Close navigation menu"
      class="text-text-muted hover:bg-bg-surface hover:text-text-primary flex h-9 w-9 items-center justify-center rounded-lg transition-colors"
    >
      <svg
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <div class="px-5 pb-6">
    <slot />
  </div>
</nav>

<script>
  function initMobileMenu() {
    const toggleEl = document.getElementById('mobile-menu-toggle');
    const drawerEl = document.getElementById('mobile-drawer');
    const backdropEl = document.getElementById('mobile-drawer-backdrop');
    const closeBtnEl = document.getElementById('mobile-drawer-close');

    if (!toggleEl || !drawerEl || !backdropEl || !closeBtnEl) return;

    // Re-assign after guard so TypeScript narrows inside closures
    const toggle: HTMLElement = toggleEl;
    const drawer: HTMLElement = drawerEl;
    const backdrop: HTMLElement = backdropEl;
    const hamburger = toggle.querySelector('.hamburger-icon') as HTMLElement | null;
    const closeIcon = toggle.querySelector('.close-icon') as HTMLElement | null;

    function openDrawer() {
      drawer.classList.remove('translate-x-full');
      drawer.classList.add('translate-x-0');
      backdrop.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      hamburger?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.add('translate-x-full');
      drawer.classList.remove('translate-x-0');
      backdrop.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      hamburger?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        closeDrawer();
      } else {
        openDrawer();
      }
    });

    closeBtnEl.addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);

    // Close on nav link click
    drawer.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener('click', closeDrawer);
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        closeDrawer();
      }
    });
  }

  // Run on initial load and on Astro page transitions
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
