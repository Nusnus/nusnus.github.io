---
import { loadMeta } from '@lib/data/loader';
import { relativeTime } from '@lib/utils/date';

const meta = await loadMeta();
const lastUpdated = meta?.lastUpdated ? relativeTime(meta.lastUpdated) : 'unknown';
---

<aside
  class="scrollbar-thin border-border/50 bg-bg-base hidden h-screen overflow-y-auto border-l px-5 py-6 lg:block"
  aria-label="Live activity panel"
>
  <!-- Header -->
  <div class="mb-5 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <h2 class="text-text-secondary text-sm font-semibold tracking-wider uppercase">
        Live Activity
      </h2>
      <span class="relative flex h-2 w-2">
        <span
          class="bg-status-active absolute inline-flex h-full w-full rounded-full opacity-75"
          style="animation: pulse-dot 2s ease-in-out infinite"
          aria-hidden="true"></span>
        <span class="bg-status-active relative inline-flex h-2 w-2 rounded-full"></span>
      </span>
    </div>
    <span class="text-text-muted text-xs">
      Updated <span data-live="lastUpdated">{lastUpdated}</span>
    </span>
  </div>

  <!-- Activity Feed (React island) -->
  <slot />
</aside>
