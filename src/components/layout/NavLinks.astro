---
/**
 * NavLinks — Shared page section navigation.
 *
 * Used in both Sidebar and MobileNav to eliminate nav link duplication.
 */
import { NAV_LINKS } from '@config';

interface Props {
  /** Extra padding for mobile-sized touch targets. */
  mobile?: boolean;
}

const { mobile = false } = Astro.props;
const linkPadding = mobile ? 'px-3 py-2' : 'px-3 py-1.5';
---

<nav class="flex flex-col gap-1" aria-label="Page sections">
  {
    NAV_LINKS.map(({ href, label }) => (
      <a
        href={href}
        class:list={[
          'text-text-secondary hover:bg-bg-surface hover:text-accent rounded-md text-sm transition-colors duration-100',
          linkPadding,
        ]}
      >
        {label}
      </a>
    ))
  }
  <a
    href="/chat"
    class:list={[
      'text-accent hover:bg-accent/10 mt-1 flex items-center gap-2 rounded-md text-sm font-medium transition-colors duration-100',
      linkPadding,
    ]}
  >
    <svg
      class="h-4 w-4"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
    </svg>
    Cybernus
  </a>
</nav>
