---
import Badge from '@components/ui/Badge.astro';
import {
  loadProfile,
  loadRepos,
  loadCeleryOrgRepos,
  loadContributionGraph,
} from '@lib/data/loader';
import { formatCompactNumber } from '@lib/utils/date';
import { SOCIAL_LINKS } from '@lib/utils/constants';

const profile = await loadProfile();
const repos = await loadRepos();
const orgRepos = await loadCeleryOrgRepos();
const graph = await loadContributionGraph();

const celeryStars = repos?.find((r) => r.fullName === 'celery/celery')?.stars ?? 0;
const totalContributions = graph?.totalContributions ?? 0;

// Collect all contributor rankings from both active and org repos
const allRepos = [...(repos ?? []), ...(orgRepos ?? [])];
const rankedRepos = allRepos
  .filter((r) => r.contributorRank != null)
  .sort((a, b) => (a.contributorRank ?? 99) - (b.contributorRank ?? 99));
---

<aside class="border-accent/30 bg-bg-base hidden h-screen flex-col border-r px-5 py-6 md:flex">
  <!-- Avatar + Status -->
  <div class="mb-4 flex items-center gap-3">
    <div class="group relative">
      <img
        src={profile?.avatarUrl ?? 'https://avatars.githubusercontent.com/u/4662342?v=4'}
        alt="Tomer Nosrati"
        width="64"
        height="64"
        class="group-hover:ring-accent/50 rounded-full ring-2 ring-transparent transition-shadow duration-200"
        loading="eager"
      />
      <div class="absolute -right-0.5 -bottom-0.5" id="status-dot-container">
        <slot name="status-dot" />
      </div>
    </div>
    <div>
      <h1 class="text-lg leading-tight font-semibold">Tomer Nosrati</h1>
      <p class="text-accent font-mono text-sm">@Nusnus</p>
    </div>
  </div>

  <!-- Tagline -->
  <blockquote class="border-accent/30 text-text-secondary mb-5 border-l-2 pl-3 text-sm italic">
    I see myself as an artist and my art comes in the form of code
  </blockquote>

  <!-- Role -->
  <div class="mb-5 flex items-center gap-2">
    <Badge variant="accent" size="md">CEO & Tech Lead</Badge>
    <span class="text-text-secondary text-sm">
      Celery · ★ <span data-live="celeryStars">{formatCompactNumber(celeryStars)}</span>
    </span>
  </div>

  <!-- Languages -->
  <div class="mb-5 flex gap-2">
    <Badge>🇮🇱 Hebrew</Badge>
    <Badge>🇺🇸 English</Badge>
    <Badge>🇨🇴 Spanish</Badge>
  </div>

  <!-- Navigation -->
  <nav class="mb-5 flex flex-col gap-1" aria-label="Page sections">
    {
      [
        { href: '#activity', label: 'Contributions' },
        { href: '#collaborations', label: 'Collaborations' },
        { href: '#activity-graph', label: 'Activity Graph' },
        { href: '#projects', label: 'Active Projects' },
        { href: '#celery-organization', label: 'Celery Organization' },
        { href: '#writing', label: 'Writing' },
        { href: '#sponsoring', label: 'Sponsoring' },
      ].map(({ href, label }) => (
        <a
          href={href}
          class="text-text-secondary hover:bg-bg-surface hover:text-accent rounded-md px-3 py-1.5 text-sm transition-colors duration-100"
        >
          {label}
        </a>
      ))
    }
    <a
      href="/chat"
      class="text-accent hover:bg-accent/10 mt-1 flex items-center gap-2 rounded-md px-3 py-1.5 text-sm font-medium transition-colors duration-100"
    >
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
      </svg>
      AI Chat
    </a>
  </nav>

  <!-- Quick Stats -->
  <div class="border-border mb-5 border-t pt-4">
    <!-- Contribution summary -->
    <p class="text-text-primary mb-3 font-mono text-sm font-semibold">
      <span data-live="totalContributions">{formatCompactNumber(totalContributions)}</span> contributions
      this year
    </p>

    {
      graph && (
        <div class="mb-4 grid grid-cols-2 gap-x-3 gap-y-1.5">
          <p class="text-text-secondary font-mono text-xs">
            <span class="text-text-primary font-medium" data-live="totalCommits">
              {formatCompactNumber(graph.totalCommits)}
            </span>{' '}
            commits
          </p>
          <p class="text-text-secondary font-mono text-xs">
            <span class="text-text-primary font-medium" data-live="totalPRs">
              {formatCompactNumber(graph.totalPRs)}
            </span>{' '}
            PRs
          </p>
          <p class="text-text-secondary font-mono text-xs">
            <span class="text-text-primary font-medium" data-live="totalReviews">
              {formatCompactNumber(graph.totalReviews)}
            </span>{' '}
            reviews
          </p>
          <p class="text-text-secondary font-mono text-xs">
            <span class="text-text-primary font-medium" data-live="totalIssues">
              {formatCompactNumber(graph.totalIssues)}
            </span>{' '}
            issues
          </p>
        </div>
      )
    }

    <!-- Contributor rankings -->
    <p class="text-text-muted mb-2 text-xs font-medium tracking-wider uppercase">
      Contributor Rankings
    </p>
    <div class="space-y-1">
      {
        rankedRepos.map((repo) => (
          <a
            href={repo.htmlUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:bg-bg-surface group flex items-center justify-between rounded-md px-2 py-1 transition-colors duration-100"
          >
            <span class="text-text-secondary group-hover:text-text-primary font-mono text-xs transition-colors">
              {repo.name}
            </span>
            <span
              class="text-accent font-mono text-xs font-semibold"
              data-live-repo={repo.fullName}
              data-live-field="contributorRank"
            >
              #{repo.contributorRank}
            </span>
          </a>
        ))
      }
    </div>
  </div>

  <!-- Spacer -->
  <div class="flex-1"></div>

  <!-- Social Links -->
  <div class="border-border flex items-center gap-3 border-t pt-4">
    {
      [
        {
          href: SOCIAL_LINKS.github,
          label: 'GitHub',
          icon: 'M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z',
        },
        {
          href: SOCIAL_LINKS.linkedin,
          label: 'LinkedIn',
          icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
        },
        {
          href: SOCIAL_LINKS.twitter,
          label: 'X / Twitter',
          icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
        },
        {
          href: SOCIAL_LINKS.email,
          label: 'Email',
          icon: 'M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z',
        },
      ].map(({ href, label, icon }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={label}
          class="text-text-muted hover:bg-bg-surface hover:text-accent flex h-9 w-9 items-center justify-center rounded-lg transition-colors duration-100"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d={icon} />
          </svg>
        </a>
      ))
    }
  </div>

  <!-- Theme Toggle -->
  <div class="mt-3" id="theme-toggle-container">
    <slot name="theme-toggle" />
  </div>
</aside>
