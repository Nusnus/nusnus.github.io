---
import { cn } from '@lib/utils/cn';

interface Props {
  class?: string;
  href?: string;
  hover?: boolean;
}

const { class: className, href, hover = true } = Astro.props;

const baseClasses = cn(
  'glass-subtle ring-border/50 rounded-xl border p-5 ring-1',
  hover &&
    'hover:ring-accent/30 hover:glow-accent-sm transition-all duration-200 hover:-translate-y-0.5',
  'motion-reduce:transition-none motion-reduce:hover:translate-y-0',
  className,
);

const Tag = href ? 'a' : 'div';
---

<Tag
  class={baseClasses}
  href={href}
  target={href ? '_blank' : undefined}
  rel={href ? 'noopener noreferrer' : undefined}
>
  <slot />
</Tag>
