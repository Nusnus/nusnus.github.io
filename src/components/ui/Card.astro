---
import { cn } from '@lib/utils/cn';

interface Props {
  class?: string;
  href?: string;
  hover?: boolean;
  glow?: boolean;
}

const { class: className, href, hover = true, glow = false } = Astro.props;

const baseClasses = cn(
  'border-border bg-bg-surface/80 rounded-xl border p-5 backdrop-blur-sm',
  'shadow-[var(--shadow-soft)]',
  hover && [
    'transition-all duration-200 ease-out',
    'hover:border-accent/30 hover:-translate-y-0.5',
    glow ? 'hover:shadow-[var(--shadow-glow)]' : 'hover:shadow-[var(--shadow-elevated)]',
  ],
  glow && 'glow-border',
  'motion-reduce:transition-none motion-reduce:hover:translate-y-0',
  className,
);

const Tag = href ? 'a' : 'div';
---

<Tag
  class={baseClasses}
  href={href}
  target={href ? '_blank' : undefined}
  rel={href ? 'noopener noreferrer' : undefined}
>
  <slot />
</Tag>
