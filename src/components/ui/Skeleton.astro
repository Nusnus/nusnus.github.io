---
import { cn } from '@lib/utils/cn';

interface Props {
  class?: string;
  width?: string;
  height?: string;
}

const { class: className, width, height } = Astro.props;

const classes = cn(
  'bg-bg-elevated animate-pulse rounded-md',
  'motion-reduce:animate-none',
  className,
);
---

<div class={classes} style={{ width, height }} aria-hidden="true"></div>
