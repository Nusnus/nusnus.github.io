---
import '@styles/global.css';
import { SITE_URL } from '@config';
// import RoastWidget from '@components/widgets/RoastWidget';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Tomer Nosrati (Nusnus) — CEO & Tech Lead, Celery Organization',
  description = 'Software engineer and open source leader. Creator of pytest-celery, top contributor to Celery. Artist who codes.',
  ogImage = '/og/default.svg',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = new URL(ogImage, SITE_URL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Title & Description -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Nusnus" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@smilingnosrati" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts: preload critical -->
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- FOUC Prevention: apply theme BEFORE any paint -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored ? stored === 'dark' : prefersDark;
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>
  </head>
  <body>
    <!-- Skip link for accessibility -->
    <a
      href="#main-content"
      class="focus:bg-accent focus:text-bg-base sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded-lg focus:px-4 focus:py-2 focus:outline-none"
    >
      Skip to main content
    </a>

    <slot />

    <!-- Roast Widget — floating 🔥 FAB with inline streaming chat bubble (hidden) -->
    {/* {Astro.url.pathname !== '/chat' && <RoastWidget client:idle />} */}

    <style>
      /* ── Roast FAB ── */
      .roast-fab {
        background: radial-gradient(circle at 30% 30%, #ff6b35, #e63946);
        box-shadow: 0 4px 15px rgba(230, 57, 70, 0.4);
        animation: fab-idle 3s ease-in-out infinite;
        position: relative;
        overflow: visible;
      }
      .roast-fab::before {
        content: '';
        position: absolute;
        inset: -4px;
        border-radius: 50%;
        border: 2px solid rgba(255, 107, 53, 0.5);
        animation: fab-sonar 3s ease-out infinite;
        pointer-events: none;
      }
      .roast-fab::after {
        content: '';
        position: absolute;
        inset: -8px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(255, 107, 53, 0.3) 0%, transparent 70%);
        animation: fab-halo 3s ease-in-out infinite;
        pointer-events: none;
        z-index: -1;
      }
      @keyframes fab-idle {
        0%,
        100% {
          transform: scale(1);
        }
        50% {
          transform: scale(1.05);
        }
      }
      @keyframes fab-sonar {
        0% {
          transform: scale(1);
          opacity: 0.6;
        }
        100% {
          transform: scale(2);
          opacity: 0;
        }
      }
      @keyframes fab-halo {
        0%,
        100% {
          opacity: 0.4;
          transform: scale(1);
        }
        50% {
          opacity: 0.8;
          transform: scale(1.3);
        }
      }
      .roast-fab:hover {
        box-shadow:
          0 6px 30px rgba(230, 57, 70, 0.6),
          0 0 50px rgba(255, 107, 53, 0.3);
      }
      .roast-fab[data-roast-level='0'] {
        animation: fab-idle 2.5s ease-in-out infinite;
        box-shadow:
          0 4px 20px rgba(230, 57, 70, 0.5),
          0 0 40px rgba(255, 107, 53, 0.2);
      }
      .roast-fab[data-roast-level='1'] {
        background: radial-gradient(circle at 30% 30%, #ff5722, #d32f2f);
        animation: fab-level1 1.8s ease-in-out infinite;
        box-shadow:
          0 4px 25px rgba(211, 47, 47, 0.6),
          0 0 50px rgba(255, 87, 34, 0.3);
      }
      .roast-fab[data-roast-level='1']::before {
        inset: -6px;
        border-width: 2px;
        border-color: transparent;
        border-top-color: #ff5722;
        border-right-color: #ff9800;
        animation: fab-spin 2s linear infinite;
      }
      .roast-fab[data-roast-level='1']::after {
        inset: -14px;
        background: radial-gradient(circle, rgba(255, 87, 34, 0.35) 0%, transparent 70%);
        animation: fab-halo 1.8s ease-in-out infinite;
      }
      @keyframes fab-level1 {
        0%,
        100% {
          transform: scale(1);
        }
        50% {
          transform: scale(1.07);
        }
      }
      @keyframes fab-spin {
        to {
          transform: rotate(360deg);
        }
      }
      .roast-fab[data-roast-level='2'] {
        background: radial-gradient(circle at 30% 30%, #ff3d00, #b71c1c);
        animation: fab-level2 1.2s ease-in-out infinite;
        box-shadow:
          0 4px 30px rgba(183, 28, 28, 0.7),
          0 0 60px rgba(255, 61, 0, 0.4),
          inset 0 0 15px rgba(255, 193, 7, 0.15);
      }
      .roast-fab[data-roast-level='2']::before {
        inset: -8px;
        border-width: 3px;
        border-color: transparent;
        border-top-color: #ff3d00;
        border-right-color: #ff9800;
        animation: fab-spin 1.2s linear infinite;
      }
      .roast-fab[data-roast-level='2']::after {
        inset: -20px;
        background: radial-gradient(
          circle,
          rgba(255, 61, 0, 0.4) 0%,
          rgba(255, 152, 0, 0.1) 50%,
          transparent 70%
        );
        animation:
          fab-flicker 0.15s ease-in-out infinite alternate,
          fab-halo 1.2s ease-in-out infinite;
      }
      @keyframes fab-level2 {
        0%,
        100% {
          transform: scale(1);
        }
        30% {
          transform: scale(1.08);
        }
        60% {
          transform: scale(1.04);
        }
        80% {
          transform: scale(1.1);
        }
      }
      @keyframes fab-flicker {
        from {
          opacity: 0.7;
        }
        to {
          opacity: 1;
        }
      }
      .roast-fab[data-roast-level='3'] {
        background: radial-gradient(circle at 30% 30%, #ff1744, #880e4f);
        animation: fab-level3 0.6s ease-in-out infinite;
        box-shadow:
          0 0 30px rgba(255, 23, 68, 0.8),
          0 0 60px rgba(136, 14, 79, 0.6),
          0 0 100px rgba(255, 87, 34, 0.3),
          inset 0 0 20px rgba(255, 193, 7, 0.3);
      }
      .roast-fab[data-roast-level='3']::before {
        inset: -10px;
        border-width: 3px;
        border-color: transparent;
        border-top-color: #ff1744;
        border-bottom-color: #ffc107;
        animation: fab-spin 0.8s linear infinite;
      }
      .roast-fab[data-roast-level='3']::after {
        inset: -30px;
        background: radial-gradient(
          circle,
          rgba(255, 23, 68, 0.5) 0%,
          rgba(255, 152, 0, 0.2) 40%,
          transparent 70%
        );
        animation:
          fab-flicker 0.1s ease-in-out infinite alternate,
          fab-halo 0.6s ease-in-out infinite;
      }
      @keyframes fab-level3 {
        0%,
        100% {
          transform: scale(1) rotate(0deg);
        }
        10% {
          transform: scale(1.12) rotate(-3deg);
        }
        30% {
          transform: scale(1.05) rotate(2deg);
        }
        50% {
          transform: scale(1.15) rotate(-2deg);
        }
        70% {
          transform: scale(1.08) rotate(3deg);
        }
        90% {
          transform: scale(1.12) rotate(-1deg);
        }
      }
      .roast-fab[data-roast-level='3'] .roast-fab-emoji {
        animation: fab-emoji-bounce 0.4s ease-in-out infinite alternate;
      }
      @keyframes fab-emoji-bounce {
        from {
          transform: scale(1) translateY(0);
        }
        to {
          transform: scale(1.15) translateY(-2px);
        }
      }
      @keyframes roast-dot {
        0%,
        80%,
        100% {
          opacity: 0.3;
          transform: scale(0.8);
        }
        40% {
          opacity: 1;
          transform: scale(1);
        }
      }
      .roast-header-btn {
        animation: roast-header-glow 2.5s ease-in-out infinite;
      }
      @keyframes roast-header-glow {
        0%,
        100% {
          filter: drop-shadow(0 0 3px rgba(255, 107, 53, 0.4));
        }
        50% {
          filter: drop-shadow(0 0 8px rgba(255, 107, 53, 0.9));
        }
      }

      /* ── Escalate button — "calling" animation ── */
      .roast-escalate-btn {
        position: relative;
        animation:
          roast-escalate-bounce 1.6s ease-in-out infinite,
          roast-escalate-glow 2s ease-in-out infinite;
      }
      .roast-escalate-btn::before {
        content: '';
        position: absolute;
        inset: -3px;
        border-radius: 8px;
        border: 2px solid rgba(255, 107, 53, 0.6);
        animation: roast-escalate-ring 2s ease-out infinite;
        pointer-events: none;
      }
      .roast-escalate-btn::after {
        content: '';
        position: absolute;
        inset: -6px;
        border-radius: 10px;
        background: radial-gradient(circle, rgba(255, 107, 53, 0.25) 0%, transparent 70%);
        animation: roast-escalate-halo 2s ease-in-out infinite;
        pointer-events: none;
        z-index: -1;
      }
      @keyframes roast-escalate-bounce {
        0%,
        100% {
          transform: translateY(0) scale(1);
        }
        20% {
          transform: translateY(-3px) scale(1.1);
        }
        40% {
          transform: translateY(0) scale(1);
        }
        55% {
          transform: translateY(-2px) scale(1.05);
        }
        70% {
          transform: translateY(0) scale(1);
        }
      }
      @keyframes roast-escalate-glow {
        0%,
        100% {
          filter: drop-shadow(0 0 4px rgba(255, 107, 53, 0.5));
        }
        50% {
          filter: drop-shadow(0 0 12px rgba(255, 107, 53, 1))
            drop-shadow(0 0 20px rgba(255, 61, 0, 0.4));
        }
      }
      @keyframes roast-escalate-ring {
        0% {
          transform: scale(1);
          opacity: 0.7;
        }
        70% {
          transform: scale(1.4);
          opacity: 0;
        }
        100% {
          transform: scale(1.4);
          opacity: 0;
        }
      }
      @keyframes roast-escalate-halo {
        0%,
        100% {
          opacity: 0.3;
          transform: scale(1);
        }
        50% {
          opacity: 0.7;
          transform: scale(1.2);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .roast-fab,
        .roast-fab::before,
        .roast-fab::after,
        .roast-fab-emoji,
        .roast-header-btn,
        .roast-escalate-btn,
        .roast-escalate-btn::before,
        .roast-escalate-btn::after {
          animation: none !important;
        }
      }
    </style>
  </body>
</html>
