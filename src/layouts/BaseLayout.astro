---
import '@styles/global.css';
import { SITE_URL } from '@config';
import RoastWidget from '@components/widgets/RoastWidget';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Tomer Nosrati (Nusnus) — CEO & Tech Lead, Celery Organization',
  description = 'Software engineer and open source leader. Creator of pytest-celery, top contributor to Celery. Artist who codes.',
  ogImage = '/og/default.svg',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = new URL(ogImage, SITE_URL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Title & Description -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Nusnus" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@smilingnosrati" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts: preload critical -->
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- FOUC Prevention: apply theme BEFORE any paint -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored ? stored === 'dark' : prefersDark;
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>
  </head>
  <body>
    <!-- Skip link for accessibility -->
    <a
      href="#main-content"
      class="focus:bg-accent focus:text-bg-base sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded-lg focus:px-4 focus:py-2 focus:outline-none"
    >
      Skip to main content
    </a>

    <slot />

    <!-- Roast Widget — floating 🔥 FAB with inline streaming chat bubble -->
    {Astro.url.pathname !== '/chat' && <RoastWidget client:idle />}

    <style>
      /* ── Roast FAB base ── */
      .roast-fab {
        background: radial-gradient(circle at 30% 30%, #ff6b35, #e63946);
        box-shadow:
          0 4px 15px rgba(230, 57, 70, 0.4),
          0 0 30px rgba(255, 107, 53, 0.15);
        animation: fab-breathe 3s ease-in-out infinite;
      }
      .roast-fab:hover {
        box-shadow:
          0 6px 25px rgba(230, 57, 70, 0.6),
          0 0 50px rgba(255, 107, 53, 0.35);
      }
      @keyframes fab-breathe {
        0%,
        100% {
          box-shadow:
            0 4px 15px rgba(230, 57, 70, 0.4),
            0 0 20px rgba(255, 107, 53, 0.1);
          transform: scale(1);
        }
        50% {
          box-shadow:
            0 4px 25px rgba(230, 57, 70, 0.55),
            0 0 45px rgba(255, 107, 53, 0.3);
          transform: scale(1.04);
        }
      }

      /* ── Expanding ring pulses (CTA attention-grabber) ── */
      .roast-ring {
        border: 2px solid rgba(255, 107, 53, 0.4);
        pointer-events: none;
      }
      .roast-ring-1 {
        animation: roast-ring-expand 3s ease-out infinite;
      }
      .roast-ring-2 {
        animation: roast-ring-expand 3s ease-out 1.5s infinite;
      }
      .roast-ring-3 {
        animation: roast-ring-expand 2s ease-out 0.7s infinite;
        border-color: rgba(230, 57, 70, 0.5);
      }
      @keyframes roast-ring-expand {
        0% {
          transform: scale(1);
          opacity: 0.6;
        }
        100% {
          transform: scale(2.2);
          opacity: 0;
        }
      }

      /* ── Level 0 (idle/default): warm ember breathe ── */
      .roast-fab[data-roast-level='-1'] {
        animation: fab-breathe 3s ease-in-out infinite;
      }

      /* ── Level 1: hotter glow, faster pulse ── */
      .roast-fab[data-roast-level='1'] {
        background: radial-gradient(circle at 30% 30%, #ff5722, #d32f2f);
        animation: fab-level1 2s ease-in-out infinite;
      }
      @keyframes fab-level1 {
        0%,
        100% {
          box-shadow:
            0 4px 20px rgba(211, 47, 47, 0.5),
            0 0 35px rgba(255, 87, 34, 0.25);
        }
        50% {
          box-shadow:
            0 4px 30px rgba(211, 47, 47, 0.7),
            0 0 60px rgba(255, 87, 34, 0.4);
        }
      }
      .roast-fab[data-roast-level='1'] .roast-ring {
        border-color: rgba(255, 87, 34, 0.5);
      }

      /* ── Level 2: nuclear orange, rapid pulse with double ring ── */
      .roast-fab[data-roast-level='2'] {
        background: radial-gradient(circle at 30% 30%, #ff3d00, #b71c1c);
        animation: fab-level2 1.4s ease-in-out infinite;
      }
      @keyframes fab-level2 {
        0%,
        100% {
          box-shadow:
            0 4px 25px rgba(183, 28, 28, 0.6),
            0 0 50px rgba(255, 61, 0, 0.3),
            inset 0 0 15px rgba(255, 152, 0, 0.15);
          transform: scale(1);
        }
        50% {
          box-shadow:
            0 4px 35px rgba(183, 28, 28, 0.8),
            0 0 70px rgba(255, 61, 0, 0.5),
            inset 0 0 20px rgba(255, 152, 0, 0.25);
          transform: scale(1.06);
        }
      }
      .roast-fab[data-roast-level='2'] .roast-ring {
        border-color: rgba(255, 61, 0, 0.6);
      }
      .roast-fab[data-roast-level='2'] .roast-ring-1 {
        animation-duration: 2s;
      }
      .roast-fab[data-roast-level='2'] .roast-ring-2 {
        animation-duration: 2s;
        animation-delay: 1s;
      }

      /* ── Level 3: full unhinged — violent pulse, magenta fire, triple ring ── */
      .roast-fab[data-roast-level='3'] {
        background: radial-gradient(circle at 30% 30%, #ff1744, #880e4f);
        animation: fab-level3 0.9s ease-in-out infinite;
      }
      @keyframes fab-level3 {
        0%,
        100% {
          box-shadow:
            0 4px 30px rgba(136, 14, 79, 0.7),
            0 0 60px rgba(255, 23, 68, 0.4),
            0 0 100px rgba(255, 61, 0, 0.15),
            inset 0 0 20px rgba(255, 193, 7, 0.2);
          transform: scale(1);
        }
        25% {
          transform: scale(1.08) rotate(2deg);
        }
        50% {
          box-shadow:
            0 4px 40px rgba(136, 14, 79, 0.9),
            0 0 80px rgba(255, 23, 68, 0.6),
            0 0 120px rgba(255, 61, 0, 0.3),
            inset 0 0 25px rgba(255, 193, 7, 0.35);
          transform: scale(1.1);
        }
        75% {
          transform: scale(1.08) rotate(-2deg);
        }
      }
      .roast-fab[data-roast-level='3'] .roast-ring {
        border-color: rgba(255, 23, 68, 0.7);
        border-width: 3px;
      }
      .roast-fab[data-roast-level='3'] .roast-ring-1 {
        animation-duration: 1.4s;
      }
      .roast-fab[data-roast-level='3'] .roast-ring-2 {
        animation-duration: 1.4s;
        animation-delay: 0.5s;
      }
      .roast-fab[data-roast-level='3'] .roast-ring-3 {
        animation-duration: 1.2s;
        animation-delay: 0.3s;
        border-color: rgba(255, 193, 7, 0.5);
      }

      /* ── Loading dots ── */
      @keyframes roast-dot {
        0%,
        80%,
        100% {
          opacity: 0.3;
          transform: scale(0.8);
        }
        40% {
          opacity: 1;
          transform: scale(1);
        }
      }
      .roast-header-btn {
        animation: roast-header-glow 2.5s ease-in-out infinite;
      }
      @keyframes roast-header-glow {
        0%,
        100% {
          filter: drop-shadow(0 0 3px rgba(255, 107, 53, 0.4));
        }
        50% {
          filter: drop-shadow(0 0 8px rgba(255, 107, 53, 0.9));
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .roast-fab,
        .roast-ring,
        .roast-header-btn {
          animation: none;
        }
      }
    </style>
  </body>
</html>
