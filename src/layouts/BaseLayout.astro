---
import '@styles/global.css';
import { SITE_URL, SOCIAL_LINKS } from '@config';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Tomer Nosrati (Nusnus) — CEO & Tech Lead, Celery Organization',
  description = 'Software engineer and open source leader. Creator of pytest-celery, top contributor to Celery. Artist who codes.',
  ogImage = '/og/default.png',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = new URL(ogImage, SITE_URL).href;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Tomer Nosrati',
  alternateName: 'Nusnus',
  url: SITE_URL,
  image: 'https://avatars.githubusercontent.com/u/4662342?v=4',
  jobTitle: 'CEO & Tech Lead, Celery Organization',
  description:
    'Software engineer and open source leader. Creator of pytest-celery, top contributor to Celery.',
  sameAs: [SOCIAL_LINKS.github, SOCIAL_LINKS.linkedin, SOCIAL_LINKS.twitter],
  knowsAbout: [
    'Distributed Systems',
    'Open Source',
    'Python',
    'Celery',
    'Software Testing',
    'End-to-End Testing',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Title & Description -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Nusnus" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@smilingnosrati" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- RSS feed -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Tomer Nosrati — Writing"
      href="/rss.xml"
    />

    <!-- Structured data: Person -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} is:inline />

    <!-- Fonts: preload critical -->
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- FOUC Prevention: apply theme BEFORE any paint -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored ? stored === 'dark' : prefersDark;
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>
  </head>
  <body>
    <!-- Skip link for accessibility -->
    <a
      href="#main-content"
      class="focus:bg-accent focus:text-bg-base sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded-lg focus:px-4 focus:py-2 focus:outline-none"
    >
      Skip to main content
    </a>

    <slot />
  </body>
</html>
