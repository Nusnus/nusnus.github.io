---
import '@styles/global.css';
import { SITE_URL } from '@lib/utils/constants';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Tomer Nosrati (Nusnus) — CEO & Tech Lead, Celery Organization',
  description = 'Software engineer and open source leader. Creator of pytest-celery, top contributor to Celery. Artist who codes.',
  ogImage = '/og/default.svg',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = new URL(ogImage, SITE_URL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Title & Description -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Nusnus" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@smilingnosrati" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts: preload critical -->
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- FOUC Prevention: apply theme BEFORE any paint -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored ? stored === 'dark' : prefersDark;
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>
  </head>
  <body>
    <!-- Skip link for accessibility -->
    <a
      href="#main-content"
      class="focus:bg-accent focus:text-bg-base sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded-lg focus:px-4 focus:py-2 focus:outline-none"
    >
      Skip to main content
    </a>

    <slot />

    <!-- Roast FAB — floating fire button that triggers a 1-click roast via AI chat -->
    {
      Astro.url.pathname !== '/chat' && (
        <a
          href="/chat?roast=1"
          aria-label="Roast Tomer Nosrati"
          class="roast-fab group fixed right-6 bottom-6 z-50 flex h-14 w-14 items-center justify-center rounded-full shadow-lg transition-all duration-300 hover:scale-110 hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-400 focus-visible:ring-offset-2"
        >
          <span class="text-2xl transition-transform duration-300 group-hover:scale-125">🔥</span>
        </a>
      )
    }

    <style>
      .roast-fab {
        background: radial-gradient(circle at 30% 30%, #ff6b35, #e63946);
        box-shadow:
          0 4px 15px rgba(230, 57, 70, 0.4),
          0 0 30px rgba(255, 107, 53, 0.15);
        animation: fab-glow 3s ease-in-out infinite;
      }
      .roast-fab:hover {
        box-shadow:
          0 6px 25px rgba(230, 57, 70, 0.5),
          0 0 40px rgba(255, 107, 53, 0.25);
      }
      @keyframes fab-glow {
        0%,
        100% {
          box-shadow:
            0 4px 15px rgba(230, 57, 70, 0.4),
            0 0 30px rgba(255, 107, 53, 0.15);
        }
        50% {
          box-shadow:
            0 4px 20px rgba(230, 57, 70, 0.5),
            0 0 40px rgba(255, 107, 53, 0.3);
        }
      }
    </style>
  </body>
</html>
