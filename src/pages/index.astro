---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/layout/Sidebar.astro';
import MainContent from '@components/layout/MainContent.astro';
import ActivityPanel from '@components/layout/ActivityPanel.astro';
import MobileHeader from '@components/layout/MobileHeader.astro';
import MobileNav from '@components/layout/MobileNav.astro';
import ActivityOverview from '@components/sections/ActivityOverview.astro';
import Collaborations from '@components/sections/Collaborations.astro';
import ActivityGraphSection from '@components/sections/ActivityGraphSection.astro';
import Projects from '@components/sections/Projects.astro';
import CeleryOrganization from '@components/sections/CeleryOrganization.astro';
import Articles from '@components/sections/Articles.astro';
import Sponsoring from '@components/sections/Sponsoring.astro';
import ThemeToggle from '@components/widgets/ThemeToggle';
import StatusDot from '@components/widgets/StatusDot.astro';
import ActivityFeed from '@components/widgets/ActivityFeed';
import LiveData from '@components/widgets/LiveData';
import { loadActivity } from '@lib/data/loader';
import { SOCIAL_LINKS } from '@config';

const activity = await loadActivity();
const lastEventTime = activity?.events[0]?.createdAt ?? new Date().toISOString();
---

<BaseLayout>
  <!-- Mobile Header + Drawer (visible only below md) -->
  <MobileHeader>
    <MobileNav />
  </MobileHeader>

  <div
    class="grid min-h-screen grid-cols-1 md:h-screen md:grid-cols-[280px_1fr] lg:grid-cols-[280px_1fr_340px]"
  >
    <!-- Sidebar (hidden on mobile, shown on md+) -->
    <Sidebar>
      <StatusDot lastEventTimestamp={lastEventTime} slot="status-dot" />
      <ThemeToggle client:idle slot="theme-toggle" />
    </Sidebar>

    <!-- Main Content -->
    <MainContent>
      <!-- Hero Banner -->
      <section class="flex flex-col items-center py-8 text-center sm:py-12" aria-label="Hero">
        <h2 class="text-3xl font-extrabold tracking-tight sm:text-5xl md:text-6xl">
          Tomer Nosrati
        </h2>
        <p class="text-text-secondary mt-3 text-base sm:mt-4 sm:text-lg">
          CEO & Tech Lead ·
          <a
            href="https://github.com/celery"
            class="text-accent hover:underline"
            target="_blank"
            rel="noopener noreferrer">Celery Organization</a
          >
        </p>
        <p class="text-text-muted mt-1.5 text-sm italic sm:mt-2 sm:text-base">
          Building the backbone of distributed Python
        </p>
        <div class="mt-4 flex items-center gap-4 sm:mt-6 sm:gap-6">
          <a
            href={SOCIAL_LINKS.linkedin}
            class="text-text-muted hover:text-text-primary text-xs font-semibold tracking-widest uppercase transition-colors"
            target="_blank"
            rel="noopener noreferrer">LinkedIn</a
          >
          <a
            href={SOCIAL_LINKS.twitter}
            class="text-text-muted hover:text-text-primary text-xs font-semibold tracking-widest uppercase transition-colors"
            target="_blank"
            rel="noopener noreferrer">X</a
          >
          <a
            href={SOCIAL_LINKS.github}
            class="text-text-muted hover:text-text-primary text-xs font-semibold tracking-widest uppercase transition-colors"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
        </div>
      </section>

      <ActivityOverview />
      <Collaborations />
      <ActivityGraphSection />
      <Projects />
      <CeleryOrganization />
      <Articles />
      <Sponsoring />
    </MainContent>

    <!-- Activity Panel (hidden on md and below) -->
    <ActivityPanel>
      <ActivityFeed client:idle initialEvents={activity?.events?.slice(0, 10) ?? []} />
    </ActivityPanel>
  </div>

  <!-- Invisible island: fetches live data from worker and updates all data-live elements -->
  <LiveData client:load />
</BaseLayout>
