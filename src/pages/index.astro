---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/layout/Sidebar.astro';
import MainContent from '@components/layout/MainContent.astro';
import ActivityPanel from '@components/layout/ActivityPanel.astro';
import MobileHeader from '@components/layout/MobileHeader.astro';
import MobileNav from '@components/layout/MobileNav.astro';
import ActivityOverview from '@components/sections/ActivityOverview.astro';
import Collaborations from '@components/sections/Collaborations.astro';
import ActivityGraphSection from '@components/sections/ActivityGraphSection.astro';
import Projects from '@components/sections/Projects.astro';
import CeleryOrganization from '@components/sections/CeleryOrganization.astro';
import Articles from '@components/sections/Articles.astro';
import Sponsoring from '@components/sections/Sponsoring.astro';
import ThemeToggle from '@components/widgets/ThemeToggle';
import StatusDot from '@components/widgets/StatusDot';
import ActivityFeed from '@components/widgets/ActivityFeed';
import LiveData from '@components/widgets/LiveData';
import { loadActivity } from '@lib/data/loader';
import { SOCIAL_LINKS } from '@config';

const activity = await loadActivity();
const lastEventTime = activity?.events[0]?.createdAt ?? new Date().toISOString();
---

<BaseLayout>
  <!-- Mobile Header + Drawer (visible only below md) -->
  <MobileHeader>
    <MobileNav />
  </MobileHeader>

  <div
    class="grid min-h-screen grid-cols-1 md:h-screen md:grid-cols-[280px_1fr] lg:grid-cols-[280px_1fr_340px]"
  >
    <!-- Sidebar (hidden on mobile, shown on md+) -->
    <Sidebar>
      <StatusDot client:load lastEventTimestamp={lastEventTime} slot="status-dot" />
      <ThemeToggle client:load slot="theme-toggle" />
    </Sidebar>

    <!-- Main Content -->
    <MainContent>
      <!-- Hero Banner -->
      <section class="relative flex flex-col items-center py-16 text-center" aria-label="Hero">
        <!-- Decorative glow -->
        <div
          class="pointer-events-none absolute top-1/2 left-1/2 h-64 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full opacity-20 blur-3xl"
          style="background: radial-gradient(ellipse, var(--color-accent-glow) 0%, transparent 70%)"
          aria-hidden="true"
        >
        </div>

        <h2
          class="text-gradient-accent text-5xl font-extrabold tracking-tight sm:text-6xl"
          style="animation: fade-in-up 0.6s ease-out both"
        >
          Tomer Nosrati
        </h2>
        <p
          class="text-text-secondary mt-4 text-lg"
          style="animation: fade-in-up 0.6s ease-out 0.1s both"
        >
          CEO & Tech Lead ·
          <a
            href="https://github.com/celery"
            class="text-accent hover:text-accent-hover transition-colors hover:underline"
            target="_blank"
            rel="noopener noreferrer">Celery Organization</a
          >
        </p>
        <p
          class="text-text-muted mt-2 text-base italic"
          style="animation: fade-in-up 0.6s ease-out 0.2s both"
        >
          Building the backbone of distributed Python
        </p>
        <div
          class="mt-6 flex items-center gap-3"
          style="animation: fade-in-up 0.6s ease-out 0.3s both"
        >
          <a
            href={SOCIAL_LINKS.linkedin}
            class="border-border text-text-muted hover:text-accent hover:border-accent/40 hover:glow-accent-sm inline-flex items-center gap-1.5 rounded-full border px-4 py-1.5 text-xs font-semibold tracking-wide uppercase transition-all duration-200"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
            LinkedIn
          </a>
          <a
            href={SOCIAL_LINKS.twitter}
            class="border-border text-text-muted hover:text-accent hover:border-accent/40 hover:glow-accent-sm inline-flex items-center gap-1.5 rounded-full border px-4 py-1.5 text-xs font-semibold tracking-wide uppercase transition-all duration-200"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
            X
          </a>
          <a
            href={SOCIAL_LINKS.github}
            class="border-border text-text-muted hover:text-accent hover:border-accent/40 hover:glow-accent-sm inline-flex items-center gap-1.5 rounded-full border px-4 py-1.5 text-xs font-semibold tracking-wide uppercase transition-all duration-200"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path>
            </svg>
            GitHub
          </a>
        </div>
      </section>

      <div class="reveal-section"><ActivityOverview /></div>
      <div class="reveal-section"><Collaborations /></div>
      <div class="reveal-section"><ActivityGraphSection /></div>
      <div class="reveal-section"><Projects /></div>
      <div class="reveal-section"><CeleryOrganization /></div>
      <div class="reveal-section"><Articles /></div>
      <div class="reveal-section"><Sponsoring /></div>
    </MainContent>

    <!-- Activity Panel (hidden on md and below) -->
    <ActivityPanel>
      <ActivityFeed client:load initialEvents={activity?.events ?? []} />
    </ActivityPanel>
  </div>

  <!-- Invisible island: fetches live data from worker and updates all data-live elements -->
  <LiveData client:load />
</BaseLayout>
