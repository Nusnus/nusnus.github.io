---
import BaseLayout from '@layouts/BaseLayout.astro';
import Card from '@components/ui/Card.astro';
import Badge from '@components/ui/Badge.astro';
import { LINKEDIN_ARTICLES, SOCIAL_LINKS } from '@config';
import { formatDate } from '@lib/utils/date';
---

<BaseLayout
  title="Writing — Tomer Nosrati (Nusnus)"
  description="Thoughts on distributed systems, open source leadership, and software engineering philosophy."
>
  <div class="mx-auto max-w-3xl px-6 py-12 lg:py-20">
    <!-- Header -->
    <div class="mb-10">
      <div class="mb-4 flex items-center gap-3">
        <h1 class="text-4xl font-bold tracking-tight">Writing</h1>
        <Badge variant="accent" size="md">Coming Soon</Badge>
      </div>
      <p class="text-text-secondary max-w-xl text-lg">
        I write about distributed systems, open source leadership, and the philosophy of software
        engineering.
      </p>
    </div>

    <!-- Featured Writing -->
    <div class="mb-10">
      <h2 class="text-text-muted mb-4 text-sm font-semibold tracking-wider uppercase">
        Featured on LinkedIn
      </h2>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {
          LINKEDIN_ARTICLES.map((article) => (
            <Card href={article.url}>
              <Badge variant="ghost" size="sm" class="mb-3">
                LinkedIn
              </Badge>
              <h3 class="text-text-primary mb-2 text-base font-semibold">{article.title}</h3>
              <p class="text-text-secondary mb-3 text-sm">{article.excerpt}</p>
              <time class="text-text-muted text-xs" datetime={article.publishedAt}>
                {formatDate(article.publishedAt)}
              </time>
            </Card>
          ))
        }
      </div>
    </div>

    <!-- Subscribe CTA -->
    <div class="border-border bg-bg-surface rounded-xl border p-6 text-center">
      <p class="text-text-secondary mb-3">
        Blog posts are on the way. In the meantime, follow me on LinkedIn for updates.
      </p>
      <a
        href={SOCIAL_LINKS.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-accent text-bg-base hover:bg-accent-hover inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-medium transition-colors"
      >
        Follow on LinkedIn
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

    <!-- Back link -->
    <div class="mt-8">
      <a href="/" class="text-accent text-sm hover:underline">← Back to home</a>
    </div>
  </div>
</BaseLayout>
