---
/**
 * Cybernus — Tomer Nosrati's Digital Self
 *
 * An AI-powered interface to Tomer's professional universe.
 * Single model (Grok 4), Matrix theme, MCP agents, voice capabilities,
 * and full trilingual support.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import AiChat from '@components/widgets/AiChat';
import {
  loadProfile,
  loadRepos,
  loadCeleryOrgRepos,
  loadContributionGraph,
} from '@lib/data/loader';
import { buildSystemPrompt } from '@lib/ai/prompt';

const repos = (await loadRepos()) ?? [];
const orgRepos = (await loadCeleryOrgRepos()) ?? [];

const systemPrompt = buildSystemPrompt({
  profile: await loadProfile(),
  repos,
  orgRepos,
  graph: await loadContributionGraph(),
});
---

<BaseLayout title="Cybernus — AI Interface">
  <main class="h-dvh overflow-hidden">
    <AiChat client:load systemPrompt={systemPrompt} />
  </main>
</BaseLayout>
