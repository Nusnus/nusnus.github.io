---
import BaseLayout from '@layouts/BaseLayout.astro';
import AiChat from '@components/widgets/AiChat';
import {
  loadProfile,
  loadRepos,
  loadCeleryOrgRepos,
  loadContributionGraph,
} from '@lib/data/loader';
import { buildSystemPrompt } from '@lib/ai/prompt';

const repos = (await loadRepos()) ?? [];
const orgRepos = (await loadCeleryOrgRepos()) ?? [];

const systemPrompt = buildSystemPrompt({
  profile: await loadProfile(),
  repos,
  orgRepos,
  graph: await loadContributionGraph(),
});
---

<BaseLayout title="Cybernus — AI Chat">
  <div
    class="flex h-screen flex-col overflow-hidden"
    style="background: linear-gradient(135deg, #0a0a0a 0%, #001a00 50%, #0a0a0a 100%);"
  >
    <!-- Compact header — full-width -->
    <header
      class="flex shrink-0 items-center justify-between border-b border-[#00ff41]/10 px-4 py-2.5 md:px-8 lg:px-12"
      style="background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(12px);"
    >
      <div class="flex items-center gap-3">
        <a
          href="/"
          class="flex items-center gap-1.5 rounded-lg px-2 py-1 text-xs text-[#00ff41]/40 transition-all hover:bg-[#00ff41]/5 hover:text-[#00ff41]/80"
          aria-label="Back to portfolio"
        >
          <svg
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m12 19-7-7 7-7"></path>
            <path d="M19 12H5"></path>
          </svg>
          <span class="hidden sm:inline">Back</span>
        </a>
        <div class="h-4 w-px bg-[#00ff41]/8"></div>
        <div class="flex items-center gap-2">
          <span class="relative flex h-5 w-5 items-center justify-center">
            <span
              class="absolute h-full w-full animate-ping rounded-full bg-[#00ff41]/15 opacity-25"
            ></span>
            <span class="relative h-2 w-2 rounded-full bg-[#00ff41] shadow-[0_0_10px_#00ff41]"
            ></span>
          </span>
          <h1 class="text-sm font-bold tracking-[0.2em] text-[#00ff41]">CYBERNUS</h1>
        </div>
      </div>
    </header>

    <!-- Chat area — maximized -->
    <main class="min-h-0 flex-1">
      <AiChat client:load systemPrompt={systemPrompt} />
    </main>
  </div>
</BaseLayout>
