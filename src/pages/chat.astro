---
import BaseLayout from '@layouts/BaseLayout.astro';
import ThemeToggle from '@components/widgets/ThemeToggle';
import AiChat from '@components/widgets/AiChat';
import {
  loadProfile,
  loadRepos,
  loadCeleryOrgRepos,
  loadContributionGraph,
} from '@lib/data/loader';
import { buildSystemPrompt } from '@lib/ai/prompt';

const systemPrompt = buildSystemPrompt({
  profile: await loadProfile(),
  repos: (await loadRepos()) ?? [],
  orgRepos: (await loadCeleryOrgRepos()) ?? [],
  graph: await loadContributionGraph(),
});
---

<BaseLayout title="Cybernus — Tomer Nosrati">
  <div class="flex h-dvh flex-col">
    <!-- Header -->
    <header
      class="border-accent/30 bg-bg-base/80 flex shrink-0 items-center justify-between border-b px-4 py-3 backdrop-blur-sm"
    >
      <div class="flex items-center gap-3">
        <a
          href="/"
          class="text-text-muted hover:text-text-primary flex items-center gap-1.5 text-sm transition-colors"
          aria-label="Back to portfolio"
        >
          <svg
            class="size-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m12 19-7-7 7-7"></path>
            <path d="M19 12H5"></path>
          </svg>
          <span class="hidden sm:inline">Back</span>
        </a>
        <div class="bg-border h-5 w-px"></div>
        <div class="flex items-baseline gap-2">
          <h1 class="text-accent font-mono text-base font-bold tracking-wider">CYBERNUS</h1>
          <span class="text-text-muted hidden font-mono text-[10px] sm:inline">
            // digital construct
          </span>
        </div>
      </div>
      <ThemeToggle client:load />
    </header>

    <!-- Chat area — 3-column layout lives inside AiChat -->
    <div class="flex min-h-0 flex-1 flex-col">
      <AiChat client:load systemPrompt={systemPrompt} />
    </div>
  </div>
</BaseLayout>
