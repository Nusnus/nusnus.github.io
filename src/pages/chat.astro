---
/**
 * /chat — Cybernus, Tomer Nosrati's digital self.
 *
 * The page is intentionally thin: all state, streaming, and layout live
 * in the React island. No build-time data props — Cybernus fetches
 * persona/knowledge/data at runtime (browser-cached) so the same build
 * works against fresh GitHub stats without a rebuild.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import CybernusChat from '@components/cybernus/CybernusChat';
---

<BaseLayout title="Cybernus — Tomer Nosrati">
  <div class="h-screen">
    <CybernusChat client:load />
  </div>
</BaseLayout>
