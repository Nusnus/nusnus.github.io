---
import BaseLayout from '@layouts/BaseLayout.astro';
import ThemeToggle from '@components/widgets/ThemeToggle';
import LanguageToggle from '@components/widgets/LanguageToggle';
import ChatHeader from '@components/widgets/ChatHeader';
import { PersonalitySlider } from '@components/ai/PersonalitySlider';
import AiChat from '@components/widgets/AiChat';
import {
  loadProfile,
  loadRepos,
  loadCeleryOrgRepos,
  loadContributionGraph,
} from '@lib/data/loader';
import { buildSystemPrompt } from '@lib/ai/prompt';

const repos = (await loadRepos()) ?? [];
const orgRepos = (await loadCeleryOrgRepos()) ?? [];

const systemPrompt = buildSystemPrompt({
  profile: await loadProfile(),
  repos,
  orgRepos,
  graph: await loadContributionGraph(),
});
---

<BaseLayout title="AI Chat — Tomer Nosrati">
  <div class="flex h-screen flex-col">
    <!-- Matrix-inspired Header -->
    <header
      class="border-accent/20 from-bg-base via-bg-base to-bg-surface/50 relative flex shrink-0 items-center justify-between border-b bg-gradient-to-r px-4 py-3 backdrop-blur-md sm:px-6 sm:py-4"
      style="box-shadow: 0 1px 0 0 oklch(0.72 0.17 145 / 0.1), 0 4px 12px -2px oklch(0 0 0 / 0.5);"
    >
      <!-- Animated grid background -->
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.03]"
        style="background-image: linear-gradient(oklch(0.72 0.17 145 / 0.3) 1px, transparent 1px), linear-gradient(90deg, oklch(0.72 0.17 145 / 0.3) 1px, transparent 1px); background-size: 24px 24px; animation: grid-scan 20s linear infinite;"
        aria-hidden="true"
      >
      </div>

      <div class="relative z-10 flex items-center gap-4">
        <a
          href="/"
          class="group text-text-muted hover:text-accent focus-visible:text-accent focus-visible:ring-accent focus-visible:ring-offset-bg-base flex min-h-[44px] touch-manipulation items-center gap-2 rounded-lg px-2 py-1.5 text-sm transition-all duration-150 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none active:scale-95"
          aria-label="Back to portfolio"
        >
          <svg
            class="h-5 w-5 transition-transform duration-150 group-hover:-translate-x-0.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m12 19-7-7 7-7"></path>
            <path d="M19 12H5"></path>
          </svg>
          <span class="hidden font-medium sm:inline">Back</span>
        </a>

        <div class="bg-accent/20 h-6 w-px"></div>

        <ChatHeader client:load />
      </div>

      <div class="relative z-10 flex items-center gap-3 sm:gap-6">
        <div class="hidden md:block">
          <PersonalitySlider client:idle />
        </div>
        <LanguageToggle client:idle />
        <ThemeToggle client:idle />
      </div>
    </header>

    <!-- Chat area (full remaining height) -->
    <main class="relative min-h-0 flex-1 overflow-hidden">
      <!-- Subtle grid overlay -->
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.02]"
        style="background-image: linear-gradient(oklch(0.72 0.17 145 / 0.2) 1px, transparent 1px), linear-gradient(90deg, oklch(0.72 0.17 145 / 0.2) 1px, transparent 1px); background-size: 32px 32px;"
        aria-hidden="true"
      >
      </div>

      <div class="relative h-full">
        <AiChat client:load systemPrompt={systemPrompt} />
      </div>
    </main>
  </div>
</BaseLayout>
