---
import BaseLayout from '@layouts/BaseLayout.astro';
import AiChat from '@components/widgets/AiChat';
import {
  loadProfile,
  loadRepos,
  loadCeleryOrgRepos,
  loadContributionGraph,
} from '@lib/data/loader';
import { buildSystemPrompt } from '@lib/ai/prompt';

const repos = (await loadRepos()) ?? [];
const orgRepos = (await loadCeleryOrgRepos()) ?? [];

const systemPrompt = buildSystemPrompt({
  profile: await loadProfile(),
  repos,
  orgRepos,
  graph: await loadContributionGraph(),
});
---

<BaseLayout title="Cybernus — AI Chat">
  <div class="bg-bg-base flex h-screen flex-col overflow-hidden">
    <!-- Header bar — matches main site navigation style -->
    <header
      class="border-border flex shrink-0 items-center justify-between border-b px-4 py-2.5 md:px-6"
    >
      <div class="flex items-center gap-3">
        <a
          href="/"
          class="text-text-muted hover:bg-bg-elevated hover:text-text-secondary flex items-center gap-1.5 rounded-lg px-2 py-1 text-xs transition-all"
          aria-label="Back to portfolio"
        >
          <svg
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m12 19-7-7 7-7"></path>
            <path d="M19 12H5"></path>
          </svg>
          <span class="hidden sm:inline">Back</span>
        </a>
        <div class="bg-border h-4 w-px"></div>
        <div class="flex items-center gap-2">
          <span class="relative flex h-5 w-5 items-center justify-center">
            <span class="bg-accent/20 absolute h-full w-full animate-ping rounded-full opacity-30"
            ></span>
            <span
              class="bg-accent relative h-2 w-2 rounded-full shadow-[0_0_8px_var(--color-accent)]"
            ></span>
          </span>
          <h1 class="text-text-primary text-sm font-bold tracking-[0.15em]">CYBERNUS</h1>
          <span class="text-text-muted hidden text-xs sm:inline">AI Chat</span>
        </div>
      </div>
    </header>

    <!-- Chat area — maximized -->
    <main class="min-h-0 flex-1">
      <AiChat client:load systemPrompt={systemPrompt} />
    </main>
  </div>
</BaseLayout>
