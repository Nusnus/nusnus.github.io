---
import BaseLayout from '@layouts/BaseLayout.astro';
import AiChat from '@components/widgets/AiChat';
import {
  loadProfile,
  loadRepos,
  loadCeleryOrgRepos,
  loadContributionGraph,
} from '@lib/data/loader';
import { buildSystemPrompt } from '@lib/ai/prompt';

const repos = (await loadRepos()) ?? [];
const orgRepos = (await loadCeleryOrgRepos()) ?? [];

const systemPrompt = buildSystemPrompt({
  profile: await loadProfile(),
  repos,
  orgRepos,
  graph: await loadContributionGraph(),
});
---

<BaseLayout title="Cybernus — AI Chat">
  <div
    class="flex h-screen flex-col"
    style="background: linear-gradient(135deg, #0a0a0a 0%, #001a00 50%, #0a0a0a 100%);"
  >
    <!-- Header -->
    <header
      class="flex shrink-0 items-center justify-between border-b border-[#00ff41]/15 px-4 py-3 backdrop-blur-sm"
      style="background: rgba(0, 0, 0, 0.7);"
    >
      <div class="flex items-center gap-3">
        <a
          href="/"
          class="flex items-center gap-1.5 text-sm text-[#00ff41]/50 transition-colors hover:text-[#00ff41]"
          aria-label="Back to portfolio"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m12 19-7-7 7-7"></path>
            <path d="M19 12H5"></path>
          </svg>
          Back
        </a>
        <div class="h-5 w-px bg-[#00ff41]/10"></div>
        <div class="flex items-center gap-2">
          <span class="relative flex h-5 w-5 items-center justify-center">
            <span
              class="absolute h-full w-full animate-ping rounded-full bg-[#00ff41]/20 opacity-30"
            ></span>
            <span class="relative h-2.5 w-2.5 rounded-full bg-[#00ff41] shadow-[0_0_8px_#00ff41]"
            ></span>
          </span>
          <h1 class="text-sm font-bold tracking-wider text-[#00ff41]">CYBERNUS</h1>
        </div>
      </div>
    </header>

    <!-- Chat area (full remaining height) -->
    <main class="min-h-0 flex-1">
      <AiChat client:load systemPrompt={systemPrompt} />
    </main>
  </div>
</BaseLayout>
