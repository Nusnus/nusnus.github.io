---
import BaseLayout from '@layouts/BaseLayout.astro';
import ThemeToggle from '@components/widgets/ThemeToggle';
import AiChat from '@components/widgets/AiChat';
import {
  loadProfile,
  loadRepos,
  loadCeleryOrgRepos,
  loadContributionGraph,
} from '@lib/data/loader';
import { buildSystemPrompt } from '@lib/ai/prompt';
import { buildSearchIndex } from '@lib/ai/rag-index';

const repos = loadRepos() ?? [];
const orgRepos = loadCeleryOrgRepos() ?? [];

const systemPrompt = buildSystemPrompt({
  profile: loadProfile(),
  repos,
  orgRepos,
  graph: loadContributionGraph(),
});

const searchIndex = buildSearchIndex(repos, orgRepos);
---

<BaseLayout title="AI Chat — Tomer Nosrati">
  <div class="flex h-screen flex-col">
    <!-- Header -->
    <header
      class="border-accent/30 bg-bg-base/95 flex shrink-0 items-center justify-between border-b px-4 py-3 backdrop-blur-sm"
    >
      <div class="flex items-center gap-3">
        <a
          href="/"
          class="text-text-muted hover:text-text-primary flex items-center gap-1.5 text-sm transition-colors"
          aria-label="Back to portfolio"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m12 19-7-7 7-7"></path>
            <path d="M19 12H5"></path>
          </svg>
          Back
        </a>
        <div class="bg-border h-5 w-px"></div>
        <div class="flex items-center gap-2">
          <svg
            class="text-accent h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
          </svg>
          <h1 class="text-text-primary text-sm font-semibold">AI Chat</h1>
        </div>
      </div>
      <ThemeToggle client:load />
    </header>

    <!-- Chat area (full remaining height) -->
    <main class="min-h-0 flex-1">
      <AiChat client:load systemPrompt={systemPrompt} searchIndex={searchIndex} />
    </main>
  </div>
</BaseLayout>
