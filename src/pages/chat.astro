---
/**
 * /chat — The Cybernus construct.
 *
 * Full-screen chat-native page. No model picker, no server-side data loading —
 * everything is fetched client-side by buildCybernusContext() so the page
 * itself is featherweight and the context is always live.
 *
 * The RoastWidget FAB is already excluded from /chat by BaseLayout.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import CybernusChat from '@components/widgets/CybernusChat';
---

<BaseLayout title="Cybernus — Tomer Nosrati">
  <div class="h-screen overflow-hidden">
    <CybernusChat client:load />
  </div>
</BaseLayout>
