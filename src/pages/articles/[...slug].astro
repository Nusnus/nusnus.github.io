---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Badge from '@components/ui/Badge.astro';
import { formatDate } from '@lib/utils/date';

export const getStaticPaths = (async () => {
  const entries = await getCollection('articles');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { entry } = Astro.props as Props;
const { Content } = await render(entry);

const sourceLabel = entry.data.source === 'linkedin' ? 'LinkedIn' : 'X';
const sourceIcon =
  entry.data.source === 'linkedin'
    ? 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z'
    : 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z';

// Estimate reading time (~200 words/min)
const rawContent = entry.body ?? '';
const wordCount = rawContent.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(wordCount / 200));
---

<BaseLayout title={`${entry.data.title} — Tomer Nosrati`} description={entry.data.description}>
  <!-- Reading Progress Bar -->
  <div
    id="reading-progress"
    class="bg-accent/80 fixed top-0 right-0 left-0 z-50 h-0.5 origin-left scale-x-0 transition-none"
  >
  </div>

  <article class="mx-auto max-w-2xl px-5 pt-10 pb-16 sm:px-8 sm:pt-16 sm:pb-24 lg:pt-20">
    <!-- Back Navigation -->
    <nav class="mb-8 sm:mb-10">
      <a
        href="/"
        class="text-text-muted hover:text-accent group inline-flex items-center gap-1.5 text-sm transition-colors"
      >
        <svg
          class="h-4 w-4 transition-transform group-hover:-translate-x-0.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to home
      </a>
    </nav>

    <!-- Article Header -->
    <header class="mb-10 sm:mb-14">
      <!-- Tags -->
      <div class="mb-4 flex flex-wrap items-center gap-2">
        {
          entry.data.tags.map((tag: string) => (
            <Badge variant="ghost" size="sm">
              {tag}
            </Badge>
          ))
        }
      </div>

      <!-- Title -->
      <h1
        class="text-text-primary mb-4 text-3xl leading-tight font-bold tracking-tight sm:text-4xl sm:leading-tight lg:text-5xl lg:leading-tight"
      >
        {entry.data.title}
      </h1>

      <!-- Description / Subtitle -->
      <p class="text-text-secondary mb-6 text-lg leading-relaxed sm:text-xl sm:leading-relaxed">
        {entry.data.description}
      </p>

      <!-- Divider -->
      <div class="bg-accent/30 mb-6 h-px"></div>

      <!-- Meta Row: Author + Reading Time + Source -->
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <!-- Author -->
        <div class="flex items-center gap-3">
          <img
            src="https://avatars.githubusercontent.com/u/4662342?v=4"
            alt="Tomer Nosrati"
            width="40"
            height="40"
            class="rounded-full ring-2 ring-transparent"
            loading="eager"
          />
          <div>
            <p class="text-text-primary text-sm font-semibold">Tomer Nosrati</p>
            <div class="text-text-muted flex items-center gap-2 text-xs">
              <time datetime={entry.data.publishedAt.toISOString()}>
                {formatDate(entry.data.publishedAt)}
              </time>
              <span>·</span>
              <span>{readingTime} min read</span>
            </div>
          </div>
        </div>

        <!-- Source Link -->
        <a
          href={entry.data.sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="border-border bg-bg-surface hover:border-accent/40 hover:text-accent text-text-muted inline-flex items-center gap-2 rounded-lg border px-3 py-1.5 text-xs font-medium transition-all"
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d={sourceIcon}></path>
          </svg>
          View on {sourceLabel}
        </a>
      </div>
    </header>

    <!-- Article Content -->
    <div
      class="article-content prose prose-invert prose-lg prose-headings:text-text-primary prose-headings:font-bold prose-headings:tracking-tight prose-h2:mt-12 prose-h2:mb-4 prose-h2:text-2xl sm:prose-h2:text-3xl prose-h2:border-accent/20 prose-h2:border-l-2 prose-h2:pl-4 prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-xl sm:prose-h3:text-2xl prose-p:text-text-secondary prose-p:leading-relaxed prose-p:mb-6 prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-strong:text-text-primary prose-strong:font-semibold prose-code:font-mono prose-code:text-accent prose-blockquote:border-accent/30 prose-blockquote:text-text-secondary prose-blockquote:italic prose-li:text-text-secondary max-w-none"
    >
      <Content />
    </div>

    <!-- Article Footer -->
    <footer class="mt-14 sm:mt-20">
      <!-- Divider -->
      <div class="bg-border mb-8 h-px"></div>

      <!-- Author Card -->
      <div class="bg-bg-surface border-border mb-8 rounded-xl border p-5 sm:p-6">
        <div class="flex items-start gap-4">
          <img
            src="https://avatars.githubusercontent.com/u/4662342?v=4"
            alt="Tomer Nosrati"
            width="48"
            height="48"
            class="rounded-full"
            loading="lazy"
          />
          <div class="min-w-0 flex-1">
            <p class="text-text-primary text-sm font-semibold">Written by Tomer Nosrati</p>
            <p class="text-text-muted mt-0.5 text-xs">CEO & Tech Lead, Celery Organization</p>
            <p class="text-text-secondary mt-2 text-sm leading-relaxed">
              Software engineer and open source leader. Thoughts on distributed systems, open source
              leadership, and software engineering philosophy.
            </p>
            <div class="mt-3 flex flex-wrap gap-2">
              <a
                href="https://www.linkedin.com/in/tomernosrati"
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-muted hover:text-accent text-xs transition-colors"
              >
                LinkedIn
              </a>
              <span class="text-border">·</span>
              <a
                href="https://x.com/smilingnosrati"
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-muted hover:text-accent text-xs transition-colors"
              >
                X / Twitter
              </a>
              <span class="text-border">·</span>
              <a
                href="https://github.com/Nusnus"
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-muted hover:text-accent text-xs transition-colors"
              >
                GitHub
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Actions -->
      <div class="flex items-center justify-between">
        <a
          href="/"
          class="text-text-muted hover:text-accent group inline-flex items-center gap-1.5 text-sm transition-colors"
        >
          <svg
            class="h-4 w-4 transition-transform group-hover:-translate-x-0.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Back to home
        </a>
        <a
          href={entry.data.sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted hover:text-accent inline-flex items-center gap-1.5 text-sm transition-colors"
        >
          Read on {sourceLabel}
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    </footer>
  </article>

  <!-- Reading Progress Script -->
  <script>
    const bar = document.getElementById('reading-progress');
    if (bar) {
      const update = () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
        bar.style.transform = `scaleX(${progress})`;
      };
      window.addEventListener('scroll', update, { passive: true });
      update();
    }
  </script>
</BaseLayout>
