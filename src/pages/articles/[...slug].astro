---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Badge from '@components/ui/Badge.astro';
import { formatDate } from '@lib/utils/date';

export const getStaticPaths = (async () => {
  const entries = await getCollection('articles');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { entry } = Astro.props as Props;
const { Content } = await render(entry);

const sourceLabel = entry.data.source === 'linkedin' ? 'LinkedIn' : 'X';
const sourceIcon =
  entry.data.source === 'linkedin'
    ? 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z'
    : 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z';
---

<BaseLayout title={`${entry.data.title} — Tomer Nosrati`} description={entry.data.description}>
  <article class="mx-auto max-w-3xl px-6 py-12 lg:py-20">
    <!-- Header -->
    <header class="mb-10">
      <div class="mb-4 flex flex-wrap items-center gap-2">
        {
          entry.data.tags.map((tag: string) => (
            <Badge variant="ghost" size="sm">
              {tag}
            </Badge>
          ))
        }
      </div>
      <h1 class="mb-3 text-4xl font-bold tracking-tight">{entry.data.title}</h1>
      <p class="text-text-secondary mb-4 text-lg">{entry.data.description}</p>
      <div class="text-text-muted flex items-center gap-4 text-sm">
        <time datetime={entry.data.publishedAt.toISOString()}>
          {formatDate(entry.data.publishedAt)}
        </time>
        <span class="text-border">|</span>
        <a
          href={entry.data.sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted hover:text-accent inline-flex items-center gap-1.5 transition-colors"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d={sourceIcon}></path>
          </svg>
          Originally published on {sourceLabel}
        </a>
      </div>
    </header>

    <!-- Content -->
    <div
      class="prose prose-invert prose-headings:font-bold prose-a:text-accent prose-code:font-mono max-w-none"
    >
      <Content />
    </div>

    <!-- Footer -->
    <div class="border-border mt-12 flex items-center justify-between border-t pt-6">
      <a href="/" class="text-accent text-sm hover:underline">← Back to home</a>
      <a
        href={entry.data.sourceUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-muted hover:text-accent inline-flex items-center gap-1.5 text-sm transition-colors"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d={sourceIcon}></path>
        </svg>
        Read on {sourceLabel}
      </a>
    </div>
  </article>
</BaseLayout>
